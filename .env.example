# Kalbii configuration — copy to .env and edit
KMI_PASSPHRASE=change-me-please-very-secret
KMI_API_KEYS=demo-key,another-key

# Mongo — for local docker-compose use mongo://...; for Atlas paste SRV URI
MONGO_URI=mongodb://mongo:27017
MONGO_DB=kalbii

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# Image storage
DATA_DIR=/data/images

# CV backend: opencv | autoencoder | clip
CV_BACKEND=opencv

# NLP backend: vader | transformers
NLP_BACKEND=vader

# API
API_HOST=0.0.0.0
API_PORT=8000
